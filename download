{% extends "base.html" %}{% block content %}<section class="hero"><div><div class="eyebrow">Ay Sonu</div><h1>Puantaj ve Bordro</h1><p>Gelmediği günler otomatik hesaplanır, maaştan kesilir, bordro PDF alınır.</p></div></section><div class="card"><form method="get" class="form-grid compact"><div class="field"><label>Ay Seç</label><input type="month" name="month" value="{{month}}"></div><div class="field"><label>&nbsp;</label><button class="btn">Puantajı Göster</button> <a class="btn secondary" href="/admin/monthly-puantaj/pdf?month={{month}}">PDF İndir</a></div></form></div><div class="card"><table class="table"><tr><th>Personel</th><th>Bölüm</th><th>Vardiya</th><th>İş Günü</th><th>Geldi</th><th>İzin</th><th>Gelmedi</th><th>Gelmeyen Tarihler</th><th>Kesinti</th><th>Net Maaş</th><th>Bordro</th></tr>{% for r in rows %}<tr><td><b>{{r.full_name}}</b></td><td>{{r.department}}</td><td>{{r.shift_name}}<br><small>{{r.shift_start}} - {{r.shift_end}}</small></td><td>{{r.workdays}}</td><td>{{r.came_days}}</td><td>{{r.leave_days}}</td><td><b>{{r.absent_days}}</b></td><td><small>{{r.absent_list}}</small></td><td>{{'%.2f'|format(r.deduction)}} TL</td><td><b>{{'%.2f'|format(r.net_salary)}} TL</b></td><td><a class="btn small" href="/admin/payroll/{{r.id}}?month={{month}}">Bordro</a></td></tr>{% endfor %}</table></div>{% endblock %}
